# Copy this file to `.env` and fill in your keys. Never commit `.env`.

# Used for PDF segmentation (slice 1) and 5.5e conversion (slice 2).
ANTHROPIC_API_KEY=

# Used for creature image generation via gpt-image-2 (slice 3).
OPENAI_API_KEY=

# WINDOWS ONLY: path to the poppler "bin" folder. On macOS/Linux,
# leave this blank — poppler comes from `brew install poppler` or
# `apt install poppler-utils` and is found via PATH automatically.
# Example: POPPLER_PATH=C:\Program Files\poppler\Library\bin
POPPLER_PATH=
